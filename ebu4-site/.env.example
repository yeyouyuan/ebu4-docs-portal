# 复制为 .env 后填写（.gitignore 已忽略 .env）
#
# === 存储 ===
# 默认 SQLite 单库：ebu4-site/data/site.db
# SITE_SQLITE_PATH=/path/to/site.db
# 与旧版兼容：SQLITE_PATH=/path/to/site.db
#
# 全站退回 Markdown + public/data/*.json（不写库）
# SITE_STORAGE=file
#
# 仅扩展页使用 JSON 文件（与旧版一致）
# EXTRA_PAGES_USE_JSON=1
# EXTRA_PAGES_PATH=/path/to/extra-pages.json
#
# === 服务 ===
# PORT=3000
# 反向代理后开启，以便 Cookie Secure / req.ip 正确
# TRUST_PROXY=1
#
# === 管理后台 ===
# 生产环境务必设置强密码（至少 4 字符，用于首次创建管理员 admin）
# 多用户：账号存 SQLite 表 admin_users 或文件模式下的 data/admin-users.json；密码为 scrypt 哈希
# 登录：用户名+密码；仅提交密码且等于本变量时兼容旧版单密码登录（admin 账号）
# ADMIN_PASSWORD=
#
# 登录防爆破（毫秒 / 窗口内最大失败次数）
# ADMIN_LOGIN_WINDOW_MS=900000
# ADMIN_LOGIN_MAX_FAILS=15
#
# 管理 API 限流（毫秒窗口 / 每 IP 最大请求数，不含 login）
# ADMIN_API_RATE_WINDOW_MS=60000
# ADMIN_API_RATE_MAX=240
#
# HTTPS 反向代理但未感知 TLS 时强制 Secure Cookie
# FORCE_SECURE_COOKIE=1
#
# 通行密钥（WebAuthn / Passkey）后台登录与用户绑定
# 禁用：WEBAUTHN_DISABLED=1
# 生产环境建议显式设置依赖方 ID 与来源（与浏览器地址栏一致）
# WEBAUTHN_RP_ID=example.com
# WEBAUTHN_RP_NAME=EBU4
# WEBAUTHN_ORIGIN=https://example.com
#
# 主文档与 JSON 备份保留份数（1–200）
# ADMIN_BACKUP_KEEP=20
#
# === 日志与审计 ===
# 管理 API 写操作访问日志（除 GET/HEAD/OPTIONS）
# LOG_ADMIN_ACCESS=1
#
# 单行 JSON 日志关闭（改为纯文本）
# LOG_JSON=0
#
# 审计 JSON Lines 关闭
# AUDIT_LOG_ENABLED=0
# AUDIT_LOG_PATH=/path/to/admin-audit.jsonl
#
# === Redis（可选，多实例在线用户）===
# 在线心跳优先使用本变量；未设置时可在后台「Redis」写入 site_kv.site_settings
# REDIS_URL=redis://127.0.0.1:6379
# 未配置可用 Redis 时拒绝启动（需环境变量或站点设置中启用并填写地址）
# REQUIRE_REDIS=1
